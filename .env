###################################
# Front ENVIRONMENT SETTINGS
###################################
NEXT_PUBLIC_BASE_PAGES_PATH=
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_DEPLOYMENT=KUBERNETES   # Registry are called by app using their internal K8S cluster DNS URL
# NEXT_PUBLIC_DEPLOYMENT=ONPREMISES # Registry are called by app using Global network DNS URL
NEXT_PUBLIC_VERSION=1.3.0

###################################
###################################
# Backend ENVIRONMENT SETTINGS
###################################
###################################
#
###################################
# POSTGRES SETTINGS
###################################
PG_HOST=localhost
PG_PORT=5432
PG_NAME=oc-registry-browser
PG_USER=postgres
PG_PASS=postgres
PG_SSLMODE=disable
#
###################################
# REDIS SETTINGS
###################################
# Remove REDIS_HOST not to use Sessions
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PWD=fred123
REDIS_DB=0
#
###################################
# LOG SETTINGS
###################################
LOG_LEVEL=INF
# LOG_LEVEL=WRN
# LOG_LEVEL=ERR
# LOG_LEVEL=
#
###################################
# SECURITY SETTINGS
###################################
# 32 char lenght
JWT_SECRET_KEY=


###################################
# SEED PROCESS SETTINGS
##################################
#
###################################
# Deployment type
###################################
APPLICATION_DEPLOYMENT=KUBERNETES   # Registry are called by app using their internal K8S cluster DNS URL
# APPLICATION_DEPLOYMENT=ONPREMISES # Registry are called by app using Global network DNS URL
#
###################################
# Users account to seed
###################################
SEED_ADMIN_NAME=
SEED_ADMIN_PASS=

###################################
#       SEED FOR KUBERNETES
###################################
